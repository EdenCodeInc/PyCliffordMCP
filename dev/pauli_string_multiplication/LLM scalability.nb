Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["p", "0"], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"N", "-", 
          SubscriptBox["N", "crs"]}], ")"}], "/", 
        RowBox[{"\[ImplicitPlus]", 
         SubscriptBox["N", "rng"]}]}]], "+", "1"}]], "."}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"fd2d6f86-1c50-\
