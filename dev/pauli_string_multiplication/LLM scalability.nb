          RowBox[{
           SubsuperscriptBox["s", "i", "a"], 
           SubsuperscriptBox["s", "j", "a"], 
           SubsuperscriptBox["s", "i", "b"], 
           SubsuperscriptBox["s", "j", "b"]}]}]}], "+", 
        RowBox[{"h", 
         RowBox[{
          UnderscriptBox["\[Sum]", 
           RowBox[{"i", ",", "a"}]], 
          SubsuperscriptBox["s", "i", "a"]}]}]}], ")"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"with", " ", "\[CapitalOmega]"}], "=", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox[
        SubsuperscriptBox["J", "0", "2"], "4"], 
       RowBox[{"N", "(", 
        RowBox[{"N", "-", "1"}], ")"}]}], ")"}], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
