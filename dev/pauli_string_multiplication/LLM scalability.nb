Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GraphProduct", "[", 
  RowBox[{
   RowBox[{"CompleteGraph", "[", "4", "]"}], ",", 
   RowBox[{"CompleteGraph", "[", "3", "]"}], ",", 
   RowBox[{"GraphLayout", "\[Rule]", "\"\<SpringElectricalEmbedding\>\""}], 
   ",", 
   RowBox[{"VertexStyle", "->", "Black"}], ",", 
   RowBox[{"EdgeShapeFunction", "->", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"pts", ",", "e"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Switch", "[", 
         RowBox[{
          RowBox[{"PossibleZeroQ", "[", 
           RowBox[{
            RowBox[{"e", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "-", 
            RowBox[{"e", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"True", ",", "False"}], "}"}], ",", "Red", ",", 
          RowBox[{"{", 
           RowBox[{"False", ",", "True"}], "}"}], ",", "Blue", ",", "_", ",", 
          "Purple"}], "]"}], ",", 
        RowBox[{"Line", "[", "pts", "]"}]}], "}"}]}], "]"}]}], ",", 
   RowBox[{"ImageSize", "->", "100"}]}], "]"}]], "Input",
 CellLabel->
  "In[455]:=",ExpressionUUID->"7087ef6f-1eb8-4216-8b26-6d5bf6ee6051"],

