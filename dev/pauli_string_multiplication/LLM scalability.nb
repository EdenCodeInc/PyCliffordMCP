Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "file", ",", "series", ",", "models", ",", "g1", ",", "g2", ",", "g3", 
     ",", "g4"}], "}"}], ",", 
   RowBox[{
    RowBox[{"file", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", "\"\<plus\>\"", ",", 
        "\"\<records\>\"", ",", "\"\<plus_plot.pt\>\""}], "}"}], "]"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"series", "=", 
     RowBox[{"GetPy", "[", 
      RowBox[{
      "\"\<import torch, numpy as np\\n\>\"", "<>", 
       "\"\<d = torch.load(r'''\>\"", "<>", 
       RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", "<>", 
       "\"\<{k: np.stack([v['L'], v['accuracy']], axis=1).tolist() for k, v \
in d['series'].items()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"models", "=", 
     RowBox[{"Association", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"key", "->", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{
           RowBox[{"series", "[", "key", "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "\[CapitalNu]"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"\[Alpha]", " ", 
                RowBox[{"(", 
                 RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
               "\[Beta]"}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Alpha]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "0.02"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "0.01"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "0.001"}], ",", 
                  RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "0.1"}], ",", 
                  RowBox[{
                  "\"\<claude-sonnet-4-20250514\>\"", "->", "0.01"}]}], 
                 "|>"}], "[", "key", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"\[Beta]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "8"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<claude-sonnet-4-20250514\>\"", "->", "6"}]}], 
                 "|>"}], "[", "key", "]"}]}], "}"}]}], "}"}], ",", 
           "\[CapitalNu]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"key", ",", 
          RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"g1", ",", "g2", ",", "g3", ",", "g4"}], "}"}], "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"ListPlot", "[", 
          RowBox[{"series", "[", "key", "]"}], "]"}], ",", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"models", "[", "key", "]"}], "[", "\[CapitalNu]", "]"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalNu]", ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"PlotStyle", "->", "Gray"}]}], "]"}], ",", 
         RowBox[{"PlotLabel", "->", "key"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Epilog", "->", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
               "StringTemplate", "[", 
                "\"\<\\!\\(\[Beta]\\_0=`1`\\)\\n\\!\\(\[Alpha]=`2`\\)\>\"", 
                "]"}], "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"NumberForm", "[", 
                    RowBox[{"#", ",", "3"}], "]"}], "&"}], "/@", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"Exp", "[", 
                    RowBox[{"-", "\[Beta]"}], "]"}], ",", 
                    RowBox[{"Exp", "[", "\[Alpha]", "]"}]}], "}"}]}], "/.", 
                 " ", 
                 RowBox[{
                  RowBox[{"models", "[", "key", "]"}], "[", 
                  "\"\<BestFitParameters\>\"", "]"}]}], ")"}]}], ",", "12", 
              ",", 
              RowBox[{"LineSpacing", "->", 
               RowBox[{"{", 
                RowBox[{"0", ",", "12"}], "}"}]}]}], "]"}], ",", 
            RowBox[{"Scaled", "@", 
             RowBox[{"{", 
              RowBox[{"0.98", ",", "0.95"}], "}"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], ",", 
         RowBox[{"ImageSize", "->", "220"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{
           "\"\<Digit length \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
            "\"\<SAR\>\""}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"key", ",", 
         RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Column", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Row", "@", 
         RowBox[{"{", 
          RowBox[{"g1", ",", "g2"}], "}"}]}], ",", 
        RowBox[{"Row", "@", 
         RowBox[{"{", 
          RowBox[{"g3", ",", "g4"}], "}"}]}]}], "}"}], ",", 
      RowBox[{"Alignment", "->", "Center"}]}], "]"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.96902454443054*^9, 3.969024553437775*^9}, {
