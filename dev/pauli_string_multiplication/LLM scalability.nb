Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Legended", "[", 
  RowBox[{
   RowBox[{"Row", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"file", ",", "series", ",", "flashpara", ",", "propara"}], 
         "}"}], ",", 
        RowBox[{
         RowBox[{"file", "=", 
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"NotebookDirectory", "[", "]"}], ",", 
             "\"\<direct_multiplication\>\"", ",", "\"\<records\>\"", ",", 
             "\"\<pauli_multiply_all_plot.pt\>\""}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"series", "=", 
          RowBox[{"GetPy", "[", 
           RowBox[{
           "\"\<import torch\\n\>\"", "<>", "\"\<d = torch.load(r'''\>\"", "<>", 
            RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", 
            "<>", "\"\<import numpy as np\\n\>\"", "<>", 
            "\"\<{w: {m: np.stack([v['N'], v['accuracy']], axis=1).tolist() \
for (m, v) in d['series'].get(w, {}).items()} for w in \
d['series'].keys()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"propara", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[Alpha]", "->", "0.032090414663624486`"}], ",", 
            RowBox[{"\[Beta]", "->", "7.130096749863063`"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"flashpara", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[Alpha]", "->", "0.15501562496418442`"}], ",", 
            RowBox[{"\[Beta]", "->", "7.41113856362468`"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Show", "[", 
          RowBox[{
           RowBox[{"Plot", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "\[CapitalNu]"}], " ", 
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"\[Alpha]", " ", 
                   RowBox[{"(", 
                    RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
                  "\[Beta]"}], "]"}]}], "]"}], "/.", "flashpara"}], ",", 
             RowBox[{"{", 
              RowBox[{"\[CapitalNu]", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"series", "[", "\"\<direct\>\"", "]"}], "[", 
                 "\"\<gemini-2.5-flash\>\"", "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"series", "[", "\"\<direct\>\"", "]"}], "[", 
                 "\"\<gemini-2.5-flash\>\"", "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
             
             RowBox[{"PlotStyle", "->", "Gray"}], ",", 
             RowBox[{"ImageSize", "->", "220"}], ",", 
             RowBox[{"PlotRange", "->", 
              RowBox[{"{", 
               RowBox[{"All", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.05"}], ",", "1.05"}], "}"}]}], "}"}]}], ",", 
             RowBox[{"PlotLabel", "->", "\"\<Pauli (phase-strict)\>\""}]}], 
            "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Plot", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "\[CapitalNu]"}], " ", 
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"\[Alpha]", " ", 
                   RowBox[{"(", 
                    RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
                  "\[Beta]"}], "]"}]}], "]"}], "/.", "propara"}], ",", 
             RowBox[{"{", 
              RowBox[{"\[CapitalNu]", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"series", "[", "\"\<direct\>\"", "]"}], "[", 
                 "\"\<gemini-2.5-pro\>\"", "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"series", "[", "\"\<direct\>\"", "]"}], "[", 
                 "\"\<gemini-2.5-pro\>\"", "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
             
             RowBox[{"PlotStyle", "->", "Gray"}], ",", 
             RowBox[{"ImageSize", "->", "250"}], ",", 
             RowBox[{"PlotRange", "->", 
              RowBox[{"{", 
               RowBox[{"All", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.05"}], ",", "1.05"}], "}"}]}], "}"}]}], ",", 
             RowBox[{"PlotLabel", "->", "\"\<k=1 (phase-strict)\>\""}]}], 
            "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"ListPlot", "[", 
            RowBox[{
             RowBox[{"series", "[", "\"\<direct\>\"", "]"}], ",", 
