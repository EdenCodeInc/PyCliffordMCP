    GrayLevel[0], FontSize -> 12],
  Method->{"DefaultBoundaryStyle" -> Directive[
      GrayLevel[0]], 
    "DefaultGraphicsInteraction" -> {
     "Version" -> 1.2, "TrackMousePosition" -> {True, False}, 
      "Effects" -> {
       "Highlight" -> {"ratio" -> 2}, "HighlightPoint" -> {"ratio" -> 2}, 
