  FormBox["N", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "21fcee1c-da3a-4c27-9acc-3ad3f0a83b51"],
 " Ising variables, representing the correctness of the ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f0067d3a-b678-4bc0-aa75-64685b4db51a"],
 "th token ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fdb99a19-8d4f-4bdc-a944-49ec0020ed42"],
 " in the output sequence generated by the LLM."
}], "Item",ExpressionUUID->"90ab4b4c-e8df-4cfa-b275-08655e026b78"],

Cell[TextData[{
 "The",
 StyleBox[" coupling strengths",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "5a8c6e4f-f4c8-486d-b5f3-9b1ac00a8ab7"],
 " are drawn independently from ",
 StyleBox["Gaussian distribution",
  FontSlant->"Italic"],
 " with zero mean and finite variance:"
}], "Item",ExpressionUUID->"a4fccdd0-f1cf-4c26-8ee7-698099eea4c7"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
     SubscriptBox["J", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], "=", "0"}], ",", " ", 
   RowBox[{
    RowBox[{
     UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
     SubsuperscriptBox["J", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}], "2"]}], "=", 
    RowBox[{
     SubsuperscriptBox["J", "0", "2"], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellTags->
  "xref:132756",ExpressionUUID->"e52d968a-89c6-4f5b-8679-93fa5e2ee9d2"],

Cell[TextData[{
 "They model the noisy all-to-all correlation in token generation, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ad57843b-bebd-49de-8a8a-331fba92eed6"],
 " characters the ",
 StyleBox["noise strength",
  FontWeight->"Bold"],
 ", which is assumed to be ",
 StyleBox["weak",
  FontSlant->"Italic"],
 "."
}], "ItemParagraph",ExpressionUUID->"6bc1f8af-b4c5-4763-af4a-8a6e28a0622c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "cad55b07-0741-4b5d-a43d-ab8aee144f41"],
 " is the ",
 StyleBox["external magnetic field",
  FontWeight->"Bold"],
 ", parameterizing the token-level accuracy rate via Eq.\[NonBreakingSpace](",
 
 
 CounterBox["DisplayFormulaNumbered", "xref:132608"],
 "). A ",
 StyleBox["strong",
  FontSlant->"Italic"],
 " external field ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dcfa731d-8162-4035-9700-bf7fa5511307"],
 " corresponds to a high token-level accuracy, which is typically assumed."
}], "Item",ExpressionUUID->"f23eaf65-a723-4f8b-b0bc-1b89ad561d7a"],

Cell[TextData[{
 "This model is also known as the ",
 StyleBox["Sherrington-Kirkpatrick (SK) model",
  FontWeight->"Bold"],
 " in spin-glass physics."
}], "TextNoIndent",ExpressionUUID->"962a1d30-44b4-4f8e-90ac-cf2abc4231bd"],

Cell[TextData[{
 "For a particular random realization of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "16d07f09-83ce-4144-951e-a633a905bb78"],
 ", the probability to observe the Ising sequence ",
 Cell[BoxData[
  FormBox[
   StyleBox["s",
    FontWeight->"Bold"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "379075b2-8ca2-4ed6-b817-55a452ec090b"],
 " is"
}], "TextIndent",ExpressionUUID->"c48a444b-a3d6-4cc0-b394-aca0a7264d53"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["p", "J"], "[", 
     StyleBox["s",
      FontWeight->"Bold"], "]"}], "=", 
    RowBox[{
     FractionBox["1", 
      SubscriptBox["Z", "J"]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       RowBox[{
        SubscriptBox["E", "J"], "[", 
        StyleBox["s",
         FontWeight->"Bold"], "]"}]}]]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"24cc8d91-355d-\
442c-9b98-c97cb35cf488"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "J"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef7a60aa-b67b-402f-adc9-20e31710a0fb"],
 " is the partition function"
}], "TextNoIndent",ExpressionUUID->"2e48fb8c-988a-4004-a0f1-2b10a02680f5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["Z", "J"], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"[", 
      StyleBox["s",
       FontWeight->"Bold"], "]"}]], 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       RowBox[{
        SubscriptBox["E", "J"], "[", 
        StyleBox["s",
         FontWeight->"Bold"], "]"}]}]], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"0f68b513-8a9b-\
48fa-80c2-5eff6bc50b5f"],

Cell[TextData[{
 "Specifically, SAR is associated with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "J"], "[", 
    RowBox[{
     StyleBox["s",
      FontWeight->"Bold"], "=", 
     StyleBox["1",
      FontWeight->"Bold"]}], "]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9a6f72b1-9cb2-4b36-b92d-a12797fae56a"],
 " under geometric mean over random realizations of the coupling ",
 Cell[BoxData[
  FormBox["J", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4fd2a0ec-e1bb-43a3-b27d-c408df2435f7"],
 ","
}], "TextNoIndent",ExpressionUUID->"46be4e64-d8f9-4c0d-a526-3a58ebf685f0"],

Cell[BoxData[
 FormBox[
  RowBox[{"SAR", ":=", 
   RowBox[{
    RowBox[{"exp", "(", 
     RowBox[{
      UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", "log", " ", 
      RowBox[{
       SubscriptBox["p", "J"], "[", 
       RowBox[{
        StyleBox["s",
         FontWeight->"Bold"], "=", 
        StyleBox["1",
         FontWeight->"Bold"]}], "]"}]}], ")"}], "."}]}], 
  TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "xref:132880",ExpressionUUID->"1be0bfd3-d4fd-4d57-bf65-5c1cd0a196f9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Phase Diagram (Numerics)", "Subsubsection",ExpressionUUID->"39bf7836-4a94-40c5-9cec-15c154f35db6"],

Cell["\<\
To investigate the sequence accuracy phenomenon, we performed numerical \
simulations of the SK model externally in PyTorch. Here are the SAR data.\
\>", "TextIndent",ExpressionUUID->"4314c09a-2961-4355-9c41-2d41372a7f4f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ds", "=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"results", ",", "data", ",", "keys"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"results", "=", 
      RowBox[{"Import", "[", "\"\<sk_quartiles_results.json\>\"", "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"data", "=", 
      RowBox[{"Association", "[", 
       RowBox[{"\"\<data\>\"", "/.", "results"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"keys", "=", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{"Keys", "@", "data"}], ",", 
        RowBox[{"x_", "/;", 
         RowBox[{"StringMatchQ", "[", 
          RowBox[{"x", ",", 
           RowBox[{"__", "~~", "\"\<completed\>\""}]}], "]"}]}]}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Dataset", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"AssociationThread", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\"\<n\>\"", ",", "\"\<J0\>\"", ",", "\"\<h\>\"", ",", 
            "\"\<low\>\"", ",", "\"\<mid\>\"", ",", "\"\<high\>\""}], "}"}], "->", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"First", "@", 
             RowBox[{"StringCases", "[", 
              RowBox[{"#", ",", 
               RowBox[{
                RowBox[{
                "\"\<n\>\"", "~~", "n__", "~~", "\"\<_j0\>\"", "~~", "j0__", 
                 "~~", "\"\<_h\>\"", "~~", "h0__"}], ":>", 
                RowBox[{"ToExpression", "/@", 
                 RowBox[{"{", 
                  RowBox[{"n", ",", "j0", ",", "h0"}], "}"}]}]}]}], "]"}]}], 
            ",", 
            RowBox[{"\"\<quartiles\>\"", "/.", 
             RowBox[{"data", "[", "#", "]"}]}]}], "]"}]}], "]"}], "&"}], "/@",
        "keys"}], "]"}]}]}], "]"}]}]}], "Input",
 CellLabel->
  "In[753]:=",ExpressionUUID->"161e558d-bec8-4f3d-887e-51c2c9bb65b2"],

