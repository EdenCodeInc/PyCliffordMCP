        RowBox[{"(", 
         RowBox[{"c", "<", "d"}], ")"}]}]}]], 
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubsuperscriptBox["s", "i", "a"], 
       SubsuperscriptBox["s", "j", "a"], 
       SubsuperscriptBox["s", "i", "b"], 
       SubsuperscriptBox["s", "j", "b"], 
       SubsuperscriptBox["s", "k", "c"], 
       SubsuperscriptBox["s", "l", "c"], 
       SubsuperscriptBox["s", "k", "d"], 
       SubsuperscriptBox["s", "l", "d"]}], "\[RightAngleBracket]"}]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
