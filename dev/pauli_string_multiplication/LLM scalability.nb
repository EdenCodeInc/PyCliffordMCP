           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Beta]", ",", "0.1", ",", "12", ",", "0.2"}], "}"}]}], 
         "]"}], ",", "1"}], "]"}], ",", 
      RowBox[{"Contours", "->", 
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", 
         RowBox[{"{", 
          RowBox[{
          "2", ",", "5", ",", "10", ",", "20", ",", "50", ",", "100", ",", 
           "200", ",", "500", ",", "1000"}], "}"}]}], "]"}]}], ",", 
      RowBox[{"ContourLabels", "->", 
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
         RowBox[{"If", "[", 
