Cell[TextData[{
 "Define the crossover scale ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "crs"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f8bb8535-5784-4eab-bdc1-2d40a41a900d"],
 " by the solution of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"SAR", "(", 
     SubscriptBox["N", "crs"], ")"}], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "242824cb-977a-4d25-8250-abf6d6b24d1c"],
 ", Eq.\[NonBreakingSpace](",
 
