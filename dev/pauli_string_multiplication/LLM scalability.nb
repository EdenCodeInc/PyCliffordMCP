             RowBox[{"10", ",", 
              RowBox[{"\[CapitalNu]crs", "[", 
               RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}]}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", 
