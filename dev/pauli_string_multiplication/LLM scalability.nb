Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{"Log", "[", 
    RowBox[{"Root", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "h"}], "]"}]}], " ", 
         RowBox[{"Log", "[", "2", "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", " ", 
            RowBox[{"J0", "^", "2"}]}], "+", 
           RowBox[{"2", " ", 
            RowBox[{"J0", "^", "4"}]}]}], ")"}], " ", "#1"}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"J0", "^", "2"}]}], "-", 
           RowBox[{"4", " ", 
            RowBox[{"J0", "^", "4"}]}]}], ")"}], " ", 
         RowBox[{"#1", "^", "2"}]}], "+", 
        RowBox[{"2", " ", 
         RowBox[{"J0", "^", "4"}], " ", 
         RowBox[{"#1", "^", "3"}]}]}], "&"}], ",", "1"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"J0", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"h", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"Contours", "->", 
