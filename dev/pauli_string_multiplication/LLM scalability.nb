Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
     SubsuperscriptBox["Z", "J", "n"]}], "=", 
    RowBox[{
     SuperscriptBox["\[CapitalOmega]", "n"], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"[", "s", "]"}]], 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["J", "0", "2"], 
         RowBox[{
          UnderscriptBox["\[Sum]", 
           RowBox[{
            RowBox[{"i", "<", "j"}], ",", 
