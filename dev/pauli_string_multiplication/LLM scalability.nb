             RowBox[{"{", 
              RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", "Nothing"}], 
          "]"}]}], "]"}]}], ",", 
      RowBox[{"ContourStyle", "->", 
       RowBox[{"Directive", "[", 
