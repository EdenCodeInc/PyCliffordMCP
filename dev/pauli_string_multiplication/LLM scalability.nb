Cell[BoxData[
 RowBox[{"ps", "=", 
  RowBox[{"Dataset", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"dat", ",", "mdl", ",", "J0", ",", "h"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"J0", "=", 
         RowBox[{"#", "[", "\"\<J0\>\"", "]"}]}], ";", 
        RowBox[{"h", "=", 
         RowBox[{"#", "[", "\"\<h\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dat", "=", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], "}"}], ",", 
           RowBox[{"Normal", "[", 
            RowBox[{
             RowBox[{"ds", "[", 
              RowBox[{
               RowBox[{"Select", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"#J0", "==", "J0"}], "&&", 
                  RowBox[{"#h", "==", "h"}]}], "&"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"\"\<n\>\"", ",", "\"\<mid\>\""}], "}"}]}], "]"}], 
             "[", 
             RowBox[{"[", "Values", "]"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"mdl", "=", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{"dat", ",", 
           RowBox[{"LogisticSigmoid", "[", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"Exp", "[", 
               RowBox[{"-", "log\[Delta]n"}], "]"}]}], " ", 
             RowBox[{"(", 
              RowBox[{"n", "-", 
               RowBox[{"Exp", "[", "logn0", "]"}]}], ")"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"log\[Delta]n", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"logn0", ",", "1"}], "}"}]}], "}"}], ",", "n"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Merge", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"#", ",", 
            RowBox[{"KeyMap", "[", 
             RowBox[{"ToString", ",", 
              RowBox[{"Association", "[", 
               RowBox[{"mdl", "[", "\"\<BestFitParameters\>\"", "]"}], 
               "]"}]}], "]"}]}], "}"}], ",", "First"}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}], "&"}], "/@", 
    RowBox[{"Normal", "[", 
     RowBox[{"ds", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"#n", "==", "1"}], "&"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<J0\>\"", ",", "\"\<h\>\""}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[87]:=",ExpressionUUID->"7fa66430-85df-4637-8f88-e558769088e3"],

