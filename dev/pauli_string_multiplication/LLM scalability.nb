Cell[CellGroupData[{

Cell["Replica Theory", "Subsubsection",ExpressionUUID->"d7086e1a-b643-427b-9ae5-bd124c10e5ef"],

Cell[TextData[{
 "From Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:132880"],
 "), it is straight forward to show that"
}], "TextIndent",ExpressionUUID->"7b7280f4-5944-4320-a9e5-67edab23c932"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"log", " ", "SAR"}], "=", 
   RowBox[{
    RowBox[{"h", " ", "N"}], "-", 
    RowBox[{
     UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", "log", " ", 
     RowBox[{
      SubscriptBox["Z", "J"], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellTags->
  "xref:133008",ExpressionUUID->"f559f997-b3f6-4729-80a1-b0da33dd6faf"],

Cell[CellGroupData[{

Cell[TextData[{
 "Show Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:133008"],
 ")."
}], "Exercise",ExpressionUUID->"a7d55bbf-c3a4-4867-a74f-f741224df915"],

Cell[TextData[{
 "Given Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:132672"],
 "),"
}], "TextNoIndent",ExpressionUUID->"b7967c44-b3b7-4cc0-b68f-33da8f0227ad"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["E", "J"], "[", 
    RowBox[{
     StyleBox["s",
      FontWeight->"Bold"], "=", 
     StyleBox["1",
      FontWeight->"Bold"]}], "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "<", "j"}]], 
      SubscriptBox["J", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], "-", 
    RowBox[{"h", 
     RowBox[{
      UnderscriptBox["\[Sum]", "i"], "1"}]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "<", "j"}]], 
      SubscriptBox["J", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], "-", 
    RowBox[{"h", " ", 
     RowBox[{"N", "."}]}]}]}], TraditionalForm]}], "DisplayFormulaNumbered",Ex\
pressionUUID->"771404d1-0615-4b5b-b47c-fb9b789f3a7a"],

Cell[TextData[{
 "Therefore, by definition Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:132880"],
 "),"
}], "TextNoIndent",ExpressionUUID->"cb7368ed-caf2-484e-9f14-6fcc547dffa0"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{"log", " ", "SAR"}], "=", 
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", "log", " ", 
    RowBox[{
     SubscriptBox["p", "J"], "[", 
     RowBox[{
      StyleBox["s",
       FontWeight->"Bold"], "=", 
      StyleBox["1",
       FontWeight->"Bold"]}], "]"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    RowBox[{"log", "(", 
     RowBox[{
      FractionBox["1", 
       SubscriptBox["Z", "J"]], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        RowBox[{
         SubscriptBox["E", "J"], "[", 
         StyleBox["s",
          FontWeight->"Bold"], "]"}]}]]}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"log", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         RowBox[{
          SubscriptBox["E", "J"], "[", 
          StyleBox["s",
           FontWeight->"Bold"], "]"}]}]]}], "-", 
      RowBox[{"log", " ", 
       SubscriptBox["Z", "J"]}]}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{
        SubscriptBox["E", "J"], "[", 
        StyleBox["s",
         FontWeight->"Bold"], "]"}]}], "-", " ", 
      RowBox[{"log", " ", 
       SubscriptBox["Z", "J"]}]}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        UnderscriptBox["\[Sum]", 
         RowBox[{"i", "<", "j"}]], 
        SubscriptBox["J", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], "+", 
       RowBox[{"h", " ", "N"}], "-", 
       RowBox[{"log", " ", 
        SubscriptBox["Z", "J"]}]}], ")"}], "."}]}]}], 
  TraditionalForm]}], "DisplayFormulaNumbered",ExpressionUUID->"36360483-cfbf-\
4363-a194-1091096ad652"],

