Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "\[CapitalNu]crs", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalNu]crs", "[", 
      RowBox[{
       RowBox[{"\[Alpha]_", "?", "NumericQ"}], ",", 
       RowBox[{"\[Beta]_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}], "/.", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}]}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"\[Alpha]", " ", 
             RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}]}], "-", "\[Beta]"}],
            "]"}]}], "==", 
         RowBox[{"Log", "[", 
          RowBox[{"1", "/", "2"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"log\[CapitalNu]", ",", 
          RowBox[{"Log", "[", 
           RowBox[{"\[Beta]", "/", "\[Alpha]"}], "]"}]}], "}"}]}], "]"}]}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"ListContourPlot", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", "\[Beta]", ",", 
            RowBox[{"Log", "[", 
             RowBox[{"10", ",", 
              RowBox[{"\[CapitalNu]crs", "[", 
               RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}]}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", 
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"Range", "[", 
               RowBox[{"0.001", ",", "0.01", ",", "0.001"}], "]"}], ",", 
              RowBox[{"Range", "[", 
               RowBox[{"0.02", ",", "0.5", ",", "0.02"}], "]"}]}], "]"}]}], 
           "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Beta]", ",", "0.1", ",", "12", ",", "0.2"}], "}"}]}], 
         "]"}], ",", "1"}], "]"}], ",", 
      RowBox[{"Contours", "->", 
       RowBox[{"Log", "[", 
        RowBox[{"10", ",", 
         RowBox[{"{", 
          RowBox[{
          "2", ",", "5", ",", "10", ",", "20", ",", "50", ",", "100", ",", 
           "200", ",", "500", ",", "1000"}], "}"}]}], "]"}]}], ",", 
      RowBox[{"ContourLabels", "->", 
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MemberQ", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"100", ",", "50", ",", "20", ",", "10", ",", "5"}], 
              "}"}], ",", 
             RowBox[{"10", "^", "z"}]}], "]"}], ",", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{
               RowBox[{"ToString", "[", 
                RowBox[{"10", "^", "z"}], "]"}], ",", "10", ",", 
               RowBox[{"Opacity", "[", "0.5", "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ",", "Nothing"}], 
          "]"}]}], "]"}]}], ",", 
      RowBox[{"ContourStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",", 
         RowBox[{"Opacity", "[", "0.4", "]"}]}], "]"}]}], ",", 
      RowBox[{"Epilog", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Point", "[", 
               RowBox[{"{", 
                RowBox[{"0", ",", "0"}], "}"}], "]"}], ",", 
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{"#3", ",", "12"}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.5"}], ",", 
                  RowBox[{"-", "1.2"}]}], "}"}]}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"#1", ",", "#2"}], "}"}]}], "]"}], "&"}], "@@@", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0.0434", ",", "10.1", ",", "\"\<gpt\[Hyphen]5\>\""}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
            "0.0787", ",", "4.75", ",", 
             "\"\<gemini\[Hyphen]2.5\[Hyphen]pro\>\""}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
            "0.32", ",", "5.63", ",", 
             "\"\<gemini\[Hyphen]2.5\[Hyphen]flash\>\""}], "}"}]}], "}"}]}], 
        "}"}]}], ",", 
      RowBox[{"ColorFunction", "->", "\"\<BeachColors\>\""}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", "6"}], "}"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\\!\\(\[Alpha]\\)\>\"", ",", 
         "\"\<\\!\\(\[VeryThinSpace]\[Beta]\\)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<\\!\\(log N\\_crs\\)\>\""}], ",", 
      RowBox[{"ImageSize", "->", "240"}]}], "]"}]}]}], "]"}]], "Input",
