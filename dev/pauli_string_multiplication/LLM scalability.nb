Cell["This is similar to what we observed in the numerics.", "TextNoIndent",ExpressionUUID->"ca9b97f4-d4f2-4050-bba8-94dc90a0d8aa"],

Cell["import torch", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.968172701161421*^9, 3.968172710841876*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"7d49a9cc-56b4-4007-98dd-a40eb935bb75"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"SAR", "(", "N", ")"}], "=", 
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", "N"}], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"\[Alpha]", " ", "N"}], "-", "\[Beta]"}]]}], ")"}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.968175696508306*^9, 
  3.9681757216045094`*^9}},ExpressionUUID->"9b0de839-4435-48fa-aee2-\
a0f60061b38b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"file", ",", "series", ",", "models"}], "}"}], ",", 
   RowBox[{
    RowBox[{"file", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", 
        "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
        "\"\<letter_replace_13_plot.pt\>\""}], "}"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"series", "=", 
     RowBox[{"GetPy", "[", 
      RowBox[{
      "\"\<import torch, numpy as np\\n\>\"", "<>", 
       "\"\<d = torch.load(r'''\>\"", "<>", 
       RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", "<>", 
       "\"\<{k: np.stack([v['L'], v['accuracy']], axis=1).tolist() for k, v \
in d['series'].items()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"models", "=", 
     RowBox[{"Association", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"key", "->", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{
           RowBox[{"series", "[", "key", "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "\[CapitalNu]"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"\[Alpha]", " ", "\[CapitalNu]"}], "-", "\[Beta]"}], 
              "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Alpha]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "0.02"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "0.1"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "0.1"}]}], "|>"}], 
                "[", "key", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"\[Beta]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "8"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "6"}]}], "|>"}], 
                "[", "key", "]"}]}], "}"}]}], "}"}], ",", "\[CapitalNu]"}], 
          "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"key", ",", 
          RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Row", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"models", "[", "key", "]"}], "[", "\[CapitalNu]", "]"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalNu]", ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
              RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "1"}], "\[RightDoubleBracket]"}]}], 
            "}"}], ",", 
           RowBox[{"PlotStyle", "->", "Gray"}]}], "]"}], ",", 
         RowBox[{"ListPlot", "[", 
          RowBox[{"series", "[", "key", "]"}], "]"}], ",", 
         RowBox[{"PlotLabel", "->", "key"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Epilog", "->", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
               "StringTemplate", "[", 
                "\"\<\\!\\(\[Alpha]=`1`\\)\\n\\!\\(\[Beta]=`2`\\)\>\"", "]"}],
                "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"NumberForm", "[", 
                    RowBox[{"#", ",", "3"}], "]"}], "&"}], "/@", 
                  RowBox[{"{", 
                   RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}]}], "/.", 
                 RowBox[{
                  RowBox[{"models", "[", "key", "]"}], "[", 
                  "\"\<BestFitParameters\>\"", "]"}]}], ")"}]}], ",", "12", 
              ",", 
              RowBox[{"LineSpacing", "->", 
               RowBox[{"{", 
                RowBox[{"0", ",", "12"}], "}"}]}]}], "]"}], ",", 
            RowBox[{"Scaled", "@", 
             RowBox[{"{", 
              RowBox[{"0.9", ",", "0.9"}], "}"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], ",", 
         RowBox[{"ImageSize", "->", "200"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{
           "\"\<String length \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
            "\"\<SAR\>\""}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"key", ",", 
         RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.968172902194248*^9, 3.9681729021983843`*^9}, 
   3.968172982434456*^9, {3.9681730333007317`*^9, 3.968173058475925*^9}, {
   3.968174018798685*^9, 3.968174034663683*^9}, {3.96817407753721*^9, 
