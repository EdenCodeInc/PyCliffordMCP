Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    SubsuperscriptBox["Z", "J", "n"]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["\[CapitalOmega]", "n"], "(", 
      RowBox[{"2", " ", "cosh", " ", "h"}], ")"}], 
     RowBox[{"n", " ", "N"}]], 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       SubsuperscriptBox["J", "0", "2"], 
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{
         UnderscriptBox["\[Sum]", 
          RowBox[{
           RowBox[{"i", "<", "j"}], ",", 
           RowBox[{"a", "<", "b"}]}]], 
         RowBox[{
          SubsuperscriptBox["s", "i", "a"], 
          SubsuperscriptBox["s", "j", "a"], 
          SubsuperscriptBox["s", "i", "b"], 
          SubsuperscriptBox["s", "j", "b"]}]}], "\[RightAngleBracket]"}]}], 
      "+", 
      RowBox[{
       FractionBox[
        SubsuperscriptBox["J", "0", "4"], "2"], 
       RowBox[{"\[LeftAngleBracket]", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           UnderscriptBox["\[Sum]", 
            RowBox[{
             RowBox[{"i", "<", "j"}], ",", 
             RowBox[{"a", "<", "b"}]}]], 
           RowBox[{
            SubsuperscriptBox["s", "i", "a"], 
            SubsuperscriptBox["s", "j", "a"], 
            SubsuperscriptBox["s", "i", "b"], 
            SubsuperscriptBox["s", "j", "b"]}]}], ")"}], "2"], 
        "\[RightAngleBracket]"}]}], "+", "\[Ellipsis]"}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["\[CapitalOmega]", "n"], "(", 
      RowBox[{"2", " ", "cosh", " ", "h"}], ")"}], 
     RowBox[{"n", " ", "N"}]], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        FractionBox[
         SubsuperscriptBox["J", "0", "2"], "4"], "N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], " ", 
        SuperscriptBox["m", "4"]}], "+", 
       RowBox[{
        FractionBox[
         SubsuperscriptBox["J", "0", "4"], "2"], "N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          FractionBox["1", "4"], "+", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{"N", "+", "n", "-", "4"}], ")"}], 
           SuperscriptBox["m", "4"]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"N", "-", "2"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"n", "-", "2"}], ")"}], " ", 
           SuperscriptBox["m", "6"]}], "+", 
          RowBox[{
           FractionBox["1", "4"], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              FractionBox["1", "4"], "N", " ", 
              RowBox[{"(", 
               RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
              RowBox[{"(", 
               RowBox[{"n", "-", "1"}], ")"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "N"}], "-", "3"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "n"}], "-", "3"}], ")"}]}]}], ")"}], 
           SuperscriptBox["m", "8"]}]}], ")"}]}], "+", "\[Ellipsis]"}], ")"}],
      "."}]}]}], TraditionalForm]}], "DisplayFormulaNumbered",ExpressionUUID->\
"91394e27-2c8b-42ec-b4b2-560bc17302ee"]
}, Closed]],

