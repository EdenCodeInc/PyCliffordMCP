Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", "=", "3"}], ",", 
     RowBox[{"J0", "=", "0.2"}], ",", "logSAR"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"logSAR", "[", "\[CapitalNu]_", "]"}], ":=", 
