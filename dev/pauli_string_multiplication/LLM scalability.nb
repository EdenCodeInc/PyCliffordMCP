        RowBox[{"PlotStyle", "->", "Black"}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{
          RowBox[{
          "StringTemplate", "[", "\"\<\\!\\(J\\_0=`1`,h=`2`\\)\>\"", "]"}], 
