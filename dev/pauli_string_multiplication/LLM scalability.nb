Cell[TextData[{
 "However, the expectation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[DoubleStruckCapitalE]", "J"], " ", "log", " ", 
    SubscriptBox["Z", "J"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0ac6c6a6-fed0-4f3d-862d-fdb5252aba9a"],
 " in Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:133008"],
 ") is intractable. Instead, physicists introduce the \
\[OpenCurlyDoubleQuote]replica trick,\[CloseCurlyDoubleQuote] based on the \
mathematical identity:"
}], "TextNoIndent",ExpressionUUID->"a223bc63-41d2-4834-8da4-182102a29b85"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", "log", " ", 
