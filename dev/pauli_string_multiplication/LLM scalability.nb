Cell[TextData[{
 "Direct counting is non-trivial. However, we can use the fact that all \
plaquette pairs (regardless of intersection pattern) on the graph must add up \
to ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}]}], 
       RowBox[{"2", "!"}]], "\[Times]", 
      FractionBox[
       RowBox[{"n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}], 
       RowBox[{"2", "!"}]]}], ")"}], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "02997f50-195c-4c08-a5de-eebbf835881f"],
 ", subtracting from this total number by the number of all different types \
of intersecting plaquette pairs that had been counted in terms ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "A", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4f54e978-2a7c-49f3-84f1-7c2242bc3119"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "B", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eb112457-1d53-4b5d-8c73-299ecf447496"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SuperscriptBox["B", "\[Prime]"], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1866c086-2372-4956-a50f-c0483af37e09"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "C", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "49eec8c1-c16c-4327-9a88-7b73768f0800"],
 ", the remaining number must be the coefficient of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "D", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5e14d2da-9b61-43d9-8469-9f940bf89bfc"],
 "."
}], "SubitemParagraph",ExpressionUUID->"79e66187-eabf-406c-aacd-04ff2a079d37"],

Cell[TextData[{
 "Putting all terms together, Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:136622"],
 ") reads"
}], "ItemParagraph",ExpressionUUID->"5ab03d2d-d792-4cce-a71d-74871d06d9fe"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        RowBox[{
         RowBox[{"i", "<", "j"}], ",", 
         RowBox[{"a", "<", "b"}]}]], 
       RowBox[{
        SubsuperscriptBox["s", "i", "a"], 
        SubsuperscriptBox["s", "j", "a"], 
        SubsuperscriptBox["s", "i", "b"], 
        SubsuperscriptBox["s", "j", "b"]}]}], ")"}], "2"], 
    "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "4"], "N", " ", 
     RowBox[{"(", 
      RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}]}], " ", "+", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"N", "-", "2"}], ")"}], "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}], "+", 
       RowBox[{"N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "2"}], ")"}]}]}], ")"}], 
     SuperscriptBox["m", "4"]}], "+", 
    RowBox[{"N", " ", 
     RowBox[{"(", 
      RowBox[{"N", "-", "1"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"N", "-", "2"}], ")"}], "n", " ", 
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{"n", "-", "2"}], ")"}], " ", 
     SuperscriptBox["m", "6"]}], "+", 
    RowBox[{
     FractionBox["1", "4"], "N", " ", 
     RowBox[{"(", 
      RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
     RowBox[{"(", 
      RowBox[{"n", "-", "1"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox["1", "4"], "N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "N"}], "-", "3"}], ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "3"}], ")"}]}]}], ")"}], 
     SuperscriptBox["m", "8"]}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{"N", " ", 
    RowBox[{"(", 
     RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
    RowBox[{"(", 
     RowBox[{"n", "-", "1"}], ")"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", "4"], "+", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"(", 
         RowBox[{"N", "+", "n", "-", "4"}], ")"}], 
        SuperscriptBox["m", "4"]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"N", "-", "2"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"n", "-", "2"}], ")"}], " ", 
        SuperscriptBox["m", "6"]}], "+", 
       RowBox[{
        FractionBox["1", "4"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           FractionBox["1", "4"], "N", " ", 
           RowBox[{"(", 
            RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}], "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "N"}], "-", "3"}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", "n"}], "-", "3"}], ")"}]}]}], ")"}], 
        SuperscriptBox["m", "8"]}]}], ")"}], "."}]}]}], 
  TraditionalForm]}], "DisplayFormulaNumbered",ExpressionUUID->"f25e81d1-0b96-\
44b3-b0c5-b8583e7cc867"],

