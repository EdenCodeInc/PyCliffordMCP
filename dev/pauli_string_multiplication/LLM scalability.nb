   RowBox[{
    RowBox[{
     UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
     SubscriptBox["J", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
