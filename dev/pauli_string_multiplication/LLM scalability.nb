Cell[CellGroupData[{

Cell[TextData[{
 "Explain: ",
 Cell[BoxData[
  FormBox[
   UnderscriptBox["\[Sum]", 
    RowBox[{
     RowBox[{"i", "<", "j"}], ",", 
     RowBox[{"a", "<", "b"}]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1738dad5-7dd6-4d3c-bcca-32faca3ad371"],
 " counts the number of plaquettes on ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", "N"], "\[Times]", 
    SubscriptBox["K", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c82d7880-858b-4452-8ead-74c3ba2376d4"],
 ", which amounts to choosing one edge from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", "N"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4aea40d1-efba-4252-aabd-58e15524a4db"],
 " and one edge of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", "n"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aa797b2e-0861-46ce-97ee-495260638602"],
 " independently. Each summand represents a plaquette single-covered by the \
four-spin interaction."
}], "ItemParagraph",ExpressionUUID->"5d4a7e0f-b48a-4ced-a7ff-f2e19c8fa4f3"],

