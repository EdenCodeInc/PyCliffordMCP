 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"SAR", "(", 
     SubscriptBox["N", "crs"], ")"}], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "242824cb-977a-4d25-8250-abf6d6b24d1c"],
