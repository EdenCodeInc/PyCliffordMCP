Cell[TextData[{
 "This does not look like the numerics, because the perturbative expansion \
result is only valid for small ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "71dc858c-9af9-4bba-9a06-9e087a197b9f"],
 "."
}], "TextNoIndent",ExpressionUUID->"766be9b1-c40e-4948-843e-a5ee0514eeec"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Empirical Formula for SAR", "Subsubsection",ExpressionUUID->"82ff9728-6e5c-4298-8959-4656e296cf3c"],

Cell[TextData[{
 "Motivated by Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:138755"],
 "), we propose an ",
 StyleBox["empirical formula",
  FontWeight->"Bold"],
 " for SAR"
}], "TextIndent",ExpressionUUID->"56498cc7-8bcd-4c6a-b98b-b8c023f1e288"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"SAR", "(", "N", ")"}], "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "N"}], " ", 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"2", 
           SubsuperscriptBox["J", "0", "2"]}], 
          RowBox[{"1", "+", 
           RowBox[{"2", 
            SubscriptBox["J", "0"]}]}]], 
         RowBox[{"(", 
          RowBox[{"N", "-", "1"}], ")"}]}], "-", 
        RowBox[{"2", "h"}]}], ")"}]}], ")"}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "xref:142327",ExpressionUUID->"ca5a1e67-953f-4b15-b634-450fc6de844a"],

Cell[TextData[{
 "which seems to work reasonably well for a wide range of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "52e5d232-d264-44b1-b3ae-e25fae410b1f"],
 " with relatively large ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "34d18ff1-b01b-4b96-aa9b-921eecb8c8cd"],
 "."
}], "TextNoIndent",ExpressionUUID->"58630043-6fb9-411d-98dd-06131c52462c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", "=", "3"}], ",", 
     RowBox[{"J0", "=", "1"}], ",", "logSAR"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"logSAR", "[", "\[CapitalNu]_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", "\[CapitalNu]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"J0", "^", "2"}], " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"2", "J0"}]}], ")"}]}]}], "-", 
        RowBox[{"2", "h"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"logSAR", "[", "\[CapitalNu]", "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[CapitalNu]", ",", "1", ",", "16"}], "}"}], ",", 
        RowBox[{"PlotRange", "->", "All"}], ",", 
        RowBox[{"PlotStyle", "->", "Black"}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{
          RowBox[{
          "StringTemplate", "[", "\"\<\\!\\(J\\_0=`1`,h=`2`\\)\>\"", "]"}], 
          "[", 
          RowBox[{"J0", ",", "h"}], "]"}]}], ",", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{
          "\"\<System size \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
           "\"\<\\!\\(SAR\\)\>\""}], "}"}]}], ",", 
        RowBox[{"ImageSize", "->", "200"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[CapitalNu]max", "=", "16"}], ",", 
          RowBox[{"M", "=", "1000"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"ListPlot", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\[CapitalNu]", ",", 
             RowBox[{"Block", "[", 
              RowBox[{
               RowBox[{"{", "cf", "}"}], ",", 
               RowBox[{
                RowBox[{"cf", "=", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"N", "@", 
                    RowBox[{"Append", "[", 
                    RowBox[{
                    RowBox[{"Times", "@@@", 
                    RowBox[{"Subsets", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{"{", "2", "}"}]}], "]"}]}], ",", 
                    RowBox[{"Total", "[", "#", "]"}]}], "]"}]}], "&"}], "/@", 
                  
                  RowBox[{"Tuples", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
                    "\[CapitalNu]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                    RowBox[{"Around", "[", 
                    RowBox[{"#2", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"#1", "-", "#2"}], ",", 
                    RowBox[{"#3", "-", "#2"}]}], "}"}]}], "]"}], "&"}], "@@", 
                   
                   RowBox[{"Exp", "[", 
                    RowBox[{"Quartiles", "[", 
                    RowBox[{"Log", "[", 
                    RowBox[{
                    RowBox[{"Last", "@", "#"}], "/", 
                    RowBox[{"Total", "@", "#"}]}], "]"}], "]"}], "]"}]}], 
                  "&"}], "@", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"cf", ".", 
                   RowBox[{"Append", "[", 
                    RowBox[{
                    RowBox[{"J0", " ", 
                    RowBox[{"RandomVariate", "[", 
                    RowBox[{
                    RowBox[{"NormalDistribution", "[", 
                    RowBox[{"0", ",", "1"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"\[CapitalNu]", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "/", "2"}]}], 
                    ",", "M"}], "}"}]}], "]"}]}], ",", 
                    RowBox[{"ConstantArray", "[", 
                    RowBox[{"h", ",", "M"}], "]"}]}], "]"}]}], "]"}]}]}]}], 
              "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalNu]", ",", "1", ",", "\[CapitalNu]max"}], 
            "}"}]}], "]"}], "]"}]}], "]"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[790]:=",ExpressionUUID->"ee8e69ad-564c-488d-bd6d-0ef72e3ebf71"],

