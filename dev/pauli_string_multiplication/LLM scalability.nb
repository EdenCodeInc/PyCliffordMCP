Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"data", ",", "lm"}], "}"}], ",", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"First", "@", 
      RowBox[{"Cases", "[", 
       RowBox[{
        RowBox[{"ListContourPlot", "[", 
         RowBox[{
          RowBox[{"Normal", "[", 
           RowBox[{
            RowBox[{"ds", "[", 
             RowBox[{
              RowBox[{"Select", "[", 
               RowBox[{
                RowBox[{"#h", "==", "5"}], "&"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"\"\<n\>\"", ",", "\"\<J0\>\"", ",", "\"\<mid\>\""}], 
               "}"}]}], "]"}], "[", 
            RowBox[{"[", "Values", "]"}], "]"}], "]"}], ",", 
          RowBox[{"Contours", "->", 
           RowBox[{"{", "0.5", "}"}]}], ",", 
          RowBox[{"ContourShading", "->", "None"}], ",", 
          RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
        RowBox[{
         RowBox[{"GraphicsComplex", "[", 
          RowBox[{"pts_", ",", "prm_"}], "]"}], ":>", 
         RowBox[{"pts", "[", 
          RowBox[{"[", 
           RowBox[{"First", "@", 
            RowBox[{"Cases", "[", 
             RowBox[{"prm", ",", 
              RowBox[{
               RowBox[{"Line", "[", "idx_", "]"}], ":>", "idx"}], ",", 
              "\[Infinity]"}], "]"}]}], "]"}], "]"}]}], ",", "\[Infinity]"}], 
       "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"lm", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{
       RowBox[{"Log", "[", "data", "]"}], ",", "x", ",", "x"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Column", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"ListPlot", "[", 
          RowBox[{"Log", "[", "data", "]"}], "]"}], ",", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"lm", "[", "x", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "0", ",", "5"}], "}"}]}], "]"}], ",", 
         RowBox[{"Frame", "\[Rule]", "True"}], ",", 
         RowBox[{"ImageSize", "->", "180"}]}], "]"}], ",", 
       RowBox[{"lm", "[", "\"\<BestFit\>\"", "]"}]}], "}"}], "]"}]}]}], 
  "]"}]], "Input",
 CellLabel->
  "In[1815]:=",ExpressionUUID->"5225f320-fa80-46df-a3d4-823962ccbb79"],

