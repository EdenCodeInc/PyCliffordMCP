Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"file", ",", "series", ",", "models", ",", "title"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"file", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", 
        "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
        "\"\<letter_replace_all_plot.pt\>\""}], "}"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"series", "=", 
     RowBox[{"GetPy", "[", 
      RowBox[{
      "\"\<import torch\\n\>\"", "<>", "\"\<d = torch.load(r'''\>\"", "<>", 
       RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", "<>", 
       "\"\<import numpy as np\\n\>\"", "<>", 
       "\"\<{t: {m: np.stack([v['L'], v['accuracy']], axis=1).tolist() for \
(m, v) in d['series'].get(t, {}).items()} for t in d['series'].keys()}\>\""}],
       "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"models", "=", 
     RowBox[{"Association", "@", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"task", ",", "model"}], "}"}], "->", 
          RowBox[{"NonlinearModelFit", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"series", "[", "task", "]"}], "[", "model", "]"}], ",", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", "\[CapitalNu]"}], " ", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"\[Alpha]", " ", 
                 RowBox[{"(", 
                  RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
                "\[Beta]"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"\[Alpha]", ",", "0.1"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"\[Beta]", ",", "6"}], "}"}]}], "}"}], ",", 
            "\[CapitalNu]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"task", ",", 
           RowBox[{"Keys", "[", "series", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"model", ",", 
           RowBox[{"Keys", "[", 
            RowBox[{"series", "[", "task", "]"}], "]"}]}], "}"}]}], "]"}], 
       "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Legended", "[", 
     RowBox[{
      RowBox[{"Column", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Row", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Show", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"Plot", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"models", "[", 
                    RowBox[{"{", 
                    RowBox[{"#1", ",", "model"}], "}"}], "]"}], "[", 
                   "\[CapitalNu]", "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"\[CapitalNu]", ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"series", "[", "#1", "]"}], "[", "model", "]"}], 
                    "[", 
                    RowBox[{"[", 
                    RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"series", "[", "#1", "]"}], "[", "model", "]"}], 
                    "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "1"}], "]"}], "]"}]}], "}"}], 
                  ",", 
                  RowBox[{"PlotStyle", "->", "Gray"}], ",", 
                  RowBox[{"ImageSize", "->", "220"}], ",", 
                  RowBox[{"PlotRange", "->", "All"}], ",", 
                  RowBox[{"PlotLabel", "->", "#2"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"model", ",", 
                  RowBox[{"Keys", "[", 
                   RowBox[{"series", "[", "#1", "]"}], "]"}]}], "}"}]}], 
               "]"}], ",", 
              RowBox[{"ListPlot", "[", 
               RowBox[{
                RowBox[{"series", "[", "#1", "]"}], ",", 
                RowBox[{"PlotLegends", "->", "None"}]}], "]"}], ",", 
              RowBox[{"FrameLabel", "->", 
               RowBox[{"{", 
                RowBox[{
                "\"\<String length \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
                 "\"\<SAR\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"Epilog", "->", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Text", "[", 
                  RowBox[{
                   RowBox[{"Style", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    "StringTemplate", "[", 
                    "\"\<\\!\\(\[Beta]\\_0=`1`\\)\\n\\!\\(\[Alpha]=`2`\\)\>\"\
", "]"}], "@@", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"NumberForm", "[", 
                    RowBox[{"#", ",", "3"}], "]"}], "&"}], "/@", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Exp", "[", 
                    RowBox[{"-", "\[Beta]"}], "]"}], ",", 
                    RowBox[{"Exp", "[", "\[Alpha]", "]"}]}], "}"}], "/.", " ", 
                    RowBox[{
                    RowBox[{"models", "[", 
                    RowBox[{"{", 
                    RowBox[{"#1", ",", "\"\<gemini-2.5-pro\>\""}], "}"}], 
                    "]"}], "[", "\"\<BestFitParameters\>\"", "]"}]}], ")"}]}],
                     ")"}]}], ",", "12", ",", "Blue", ",", 
                    RowBox[{"LineSpacing", "->", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "12"}], "}"}]}]}], "]"}], ",", 
