      RowBox[{"(", 
       RowBox[{"N", "-", "1"}], ")"}]}], "2"], "+", 
    RowBox[{"2", 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"i", "<", "j"}]], 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        RowBox[{"a", "<", "b"}]], 
       RowBox[{
        SubsuperscriptBox["s", "i", "a"], 
        SubsuperscriptBox["s", "j", "a"], 
        SubsuperscriptBox["s", "i", "b"], 
        RowBox[{
         SubsuperscriptBox["s", "j", "b"], "."}]}]}]}]}]}]}], 
  TraditionalForm]}], "DisplayFormulaNumbered",ExpressionUUID->"11437ca1-24fe-\
45a8-bfeb-03b53f8624d3"],

Cell[TextData[{
 "Define ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalOmega]", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      SubsuperscriptBox["J", "0", "2"], 
      RowBox[{
       RowBox[{"N", "(", 
        RowBox[{"N", "-", "1"}], ")"}], "/", "4"}]}], ")"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b13a037-1fd0-47c3-9ec9-bc67fc9b9b5f"],
 " to absorb the constant factor, we have"
}], "TextNoIndent",ExpressionUUID->"f055708d-a215-4c55-90d9-db1d507c3f58"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[DoubleStruckCapitalE]", "J"], 
    SubsuperscriptBox["Z", "J", "n"]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"[", "s", "]"}]], 
    RowBox[{"exp", "(", " ", 
     RowBox[{
      RowBox[{
       FractionBox[
        SubsuperscriptBox["J", "0", "2"], "4"], "n", " ", "N", " ", 
       RowBox[{"(", 
        RowBox[{"N", "-", "1"}], ")"}]}], "+", 
      RowBox[{
       SubsuperscriptBox["J", "0", "2"], 
       RowBox[{
        UnderscriptBox["\[Sum]", 
         RowBox[{"i", "<", "j"}]], 
        RowBox[{
         UnderscriptBox["\[Sum]", 
          RowBox[{"a", "<", "b"}]], 
         RowBox[{
          SubsuperscriptBox["s", "i", "a"], 
          SubsuperscriptBox["s", "j", "a"], 
          SubsuperscriptBox["s", "i", "b"], 
          SubsuperscriptBox["s", "j", "b"]}]}]}]}], "+", 
      RowBox[{"h", 
       RowBox[{
        UnderoverscriptBox["\[Sum]", 
         RowBox[{"a", "=", "1"}], "n"], 
        RowBox[{
         UnderscriptBox["\[Sum]", "i"], 
         SubsuperscriptBox["s", "i", "a"]}]}]}]}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    SuperscriptBox["\[CapitalOmega]", "n"], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"[", "s", "]"}]], 
     RowBox[{
      RowBox[{"exp", "(", " ", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["J", "0", "2"], 
         RowBox[{
          UnderscriptBox["\[Sum]", 
           RowBox[{"i", "<", "j"}]], 
          RowBox[{
           UnderscriptBox["\[Sum]", 
            RowBox[{"a", "<", "b"}]], 
           RowBox[{
            SubsuperscriptBox["s", "i", "a"], 
            SubsuperscriptBox["s", "j", "a"], 
            SubsuperscriptBox["s", "i", "b"], 
            SubsuperscriptBox["s", "j", "b"]}]}]}]}], "+", 
        RowBox[{"h", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"a", "=", "1"}], "n"], 
          RowBox[{
           UnderscriptBox["\[Sum]", "i"], 
           SubsuperscriptBox["s", "i", "a"]}]}]}]}], ")"}], "."}]}]}]}], 
  TraditionalForm]}], "DisplayFormulaNumbered",ExpressionUUID->"dc0a074e-7c2a-\
48ee-a0d5-457224e8fc61"]
}, Closed]],

