Cell["This is similar to what we observed in the numerics.", "TextNoIndent",ExpressionUUID->"ca9b97f4-d4f2-4050-bba8-94dc90a0d8aa"],

Cell["import torch", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.968172701161421*^9, 3.968172710841876*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"7d49a9cc-56b4-4007-98dd-a40eb935bb75"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Fitting result for letter replacement task", "Subsubsection",
 CellChangeTimes->{{3.9686082562122717`*^9, 3.968608284187871*^9}, {
  3.9686186202873297`*^9, 
  3.96861862660634*^9}},ExpressionUUID->"d8a257b1-721c-4721-8968-\
180cb960cfec"],

Cell[TextData[{
 "We propose an ",
 StyleBox["empirical formula",
  FontWeight->"Bold"],
 " for SAR"
}], "TextIndent",
 CellChangeTimes->{
  3.96834245426158*^9},ExpressionUUID->"a6f352d0-3668-4dc8-a8f1-a4b6d6f8a972"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"SAR", "(", "N", ")"}], "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "N"}], " ", 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"2", 
           SubsuperscriptBox["J", "0", "2"]}], 
          RowBox[{"1", "+", 
           RowBox[{"2", 
            SubscriptBox["J", "0"]}]}]], 
         RowBox[{"(", 
          RowBox[{"N", "-", "1"}], ")"}]}], "-", 
        RowBox[{"2", "h"}]}], ")"}]}], ")"}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "xref:142327",ExpressionUUID->"f8dc7324-43c6-46f4-b7b0-cdc6070247d2"],

Cell[TextData[{
 "Define the crossover scale ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "crs"], TraditionalForm]],ExpressionUUID->
  "d2495d2a-487d-4336-a4be-92fc3b60befc"],
 " by the solution of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"SAR", "(", 
     SubscriptBox["N", "crs"], ")"}], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "5233bbff-a9a7-4dde-bf2f-e6843caa3de0"],
 ", then fit the data with formula below"
}], "TextIndent",
 CellChangeTimes->{
  3.96834245426158*^9, {3.968342507420088*^9, 3.968342554687894*^9}, {
   3.968346424933079*^9, 
   3.9683464253595953`*^9}},ExpressionUUID->"434c81aa-2ca2-4b94-850d-\
b127750804c4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"SAR", "(", "N", ")"}], "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "N"}], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"(", 
          RowBox[{"N", "-", "1"}], ")"}]}], "-", "\[Beta]"}]]}], ")"}]}], ",",
    " ", 
   RowBox[{"\[Alpha]", "=", 
    FractionBox[
     RowBox[{"2", 
      SubsuperscriptBox["J", "0", "2"]}], 
     RowBox[{"1", "+", 
      RowBox[{"2", 
       SubscriptBox["J", "0"]}]}]]}], ",", " ", 
   RowBox[{"\[Beta]", "=", 
    RowBox[{"2", "h"}]}]}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.968175696508306*^9, 3.9681757216045094`*^9}, {
  3.968342336225116*^9, 3.9683423770186987`*^9}, {3.968350596788632*^9, 
  3.968350602143656*^9}},ExpressionUUID->"9b0de839-4435-48fa-aee2-\
a0f60061b38b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Labeled", "[", 
  RowBox[{
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"file", ",", "series", ",", "models"}], "}"}], ",", 
     RowBox[{
      RowBox[{"file", "=", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
          "\"\<letter_replace_13_plot.pt\>\""}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"series", "=", 
       RowBox[{"GetPy", "[", 
        RowBox[{
        "\"\<import torch, numpy as np\\n\>\"", "<>", 
         "\"\<d = torch.load(r'''\>\"", "<>", 
         RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", 
         "<>", "\"\<{k: np.stack([v['L'], v['accuracy']], axis=1).tolist() \
for k, v in d['series'].items()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"models", "=", 
       RowBox[{"Association", "@", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"key", "->", 
           RowBox[{"NonlinearModelFit", "[", 
            RowBox[{
             RowBox[{"series", "[", "key", "]"}], ",", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", "\[CapitalNu]"}], " ", 
               RowBox[{"Exp", "[", 
                RowBox[{
                 RowBox[{"\[Alpha]", " ", 
                  RowBox[{"(", 
                   RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
                 "\[Beta]"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"\[Alpha]", ",", 
                 RowBox[{
                  RowBox[{"<|", 
                   RowBox[{
                    RowBox[{"\"\<gpt-5\>\"", "->", "0.02"}], ",", 
                    RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "0.1"}], ",", 
                    RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "0.1"}], ",", 
                    RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "0.1"}], 
                    ",", 
                    RowBox[{
                    "\"\<claude-sonnet-4-20250514\>\"", "->", "0.1"}]}], 
                   "|>"}], "[", "key", "]"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"\[Beta]", ",", 
                 RowBox[{
                  RowBox[{"<|", 
                   RowBox[{
                    RowBox[{"\"\<gpt-5\>\"", "->", "8"}], ",", 
                    RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "6"}], ",", 
                    RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "6"}], ",", 
                    RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "6"}], ",", 
                    RowBox[{"\"\<claude-sonnet-4-20250514\>\"", "->", "6"}]}],
                    "|>"}], "[", "key", "]"}]}], "}"}]}], "}"}], ",", 
             "\[CapitalNu]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"key", ",", 
            RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Row", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Show", "[", 
          RowBox[{
           RowBox[{"Plot", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"models", "[", "key", "]"}], "[", "\[CapitalNu]", "]"}],
              ",", 
             RowBox[{"{", 
              RowBox[{"\[CapitalNu]", ",", 
               RowBox[{
                RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
                RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
               RowBox[{
                RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "1"}], "\[RightDoubleBracket]"}]}], 
              "}"}], ",", 
             RowBox[{"PlotStyle", "->", "Gray"}]}], "]"}], ",", 
           RowBox[{"ListPlot", "[", 
            RowBox[{"series", "[", "key", "]"}], "]"}], ",", 
           RowBox[{"PlotLabel", "->", "key"}], ",", 
           RowBox[{"PlotRange", "->", "All"}], ",", 
           RowBox[{"Epilog", "->", 
            RowBox[{"Text", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                 "StringTemplate", "[", 
                  "\"\<\\!\\(\[Alpha]=`1`\\)\\n\\!\\(\[Beta]=`2`\\)\>\"", 
                  "]"}], "@@", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{
                    RowBox[{"NumberForm", "[", 
                    RowBox[{"#", ",", "3"}], "]"}], "&"}], "/@", 
                    RowBox[{"{", 
                    RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}]}], "/.", 
                   RowBox[{
                    RowBox[{"models", "[", "key", "]"}], "[", 
                    "\"\<BestFitParameters\>\"", "]"}]}], ")"}]}], ",", "12", 
                ",", 
                RowBox[{"LineSpacing", "->", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", "12"}], "}"}]}]}], "]"}], ",", 
              RowBox[{"Scaled", "@", 
               RowBox[{"{", 
                RowBox[{"0.9", ",", "0.9"}], "}"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], ",", 
           RowBox[{"ImageSize", "->", "200"}], ",", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
             RowBox[{
             "\"\<String length \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
              "\"\<SAR\>\""}], "}"}]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"key", ",", 
           RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}]}], "]"}], 
   ",", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<Alphabet-13 Benchmark\>\"", ",", "13", ",", 
     RowBox[{"FontFamily", "->", "\"\<CMU Serif\>\""}]}], "]"}], ",", "Top"}],
   " ", "]"}]], "Input",
 CellChangeTimes->{{3.968618701119418*^9, 3.968618763252819*^9}, {
  3.968619168341571*^9, 3.9686192167688*^9}, {3.9686202487053537`*^9, 
  3.968620248896922*^9}},
 CellLabel->
  "In[473]:=",ExpressionUUID->"5f46ce33-88a1-4a49-8227-285b9643b403"],

