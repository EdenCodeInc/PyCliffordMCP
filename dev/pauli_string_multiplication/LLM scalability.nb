Cell[CellGroupData[{

Cell[TextData[{
 "For large ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bb3b7672-4ec4-423e-be06-adde067a5476"],
 ", the difference between Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:138508"],
 ") and Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:138755"],
 ") is negligible."
}], "ItemParagraph",ExpressionUUID->"6ae612e7-bf56-48fc-8efd-58e32965a6fa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"h", "=", "3"}], ",", 
     RowBox[{"J0", "=", "0.2"}], ",", "logSAR", ",", "logSAR2"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"logSAR", "[", "\[CapitalNu]_", "]"}], ":=", 
     RowBox[{
      RowBox[{"\[CapitalNu]", 
       RowBox[{"(", 
        RowBox[{"h", "-", 
         RowBox[{"Log", "[", 
          RowBox[{"2", " ", 
           RowBox[{"Cosh", "[", "h", "]"}]}], "]"}]}], ")"}]}], "+", 
      RowBox[{
       RowBox[{
        RowBox[{"J0", "^", "2"}], "/", "4"}], "\[CapitalNu]", 
       RowBox[{"(", 
        RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{
          RowBox[{"Tanh", "[", "h", "]"}], "^", "4"}], "+", 
         RowBox[{
          RowBox[{"J0", "^", "2"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"1", "/", "2"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[CapitalNu]", "-", "4"}], ")"}], 
             RowBox[{
              RowBox[{"Tanh", "[", "h", "]"}], "^", "4"}]}], "-", 
            RowBox[{"4", 
             RowBox[{"(", 
              RowBox[{"\[CapitalNu]", "-", "2"}], ")"}], " ", 
             RowBox[{
              RowBox[{"Tanh", "[", "h", "]"}], "^", "6"}]}], "+", 
            RowBox[{
             RowBox[{"3", "/", "2"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "\[CapitalNu]"}], "-", "3"}], ")"}], 
             RowBox[{
              RowBox[{"Tanh", "[", "h", "]"}], "^", "8"}]}]}], ")"}]}]}], 
        ")"}]}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"logSAR2", "[", "\[CapitalNu]_", "]"}], ":=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], "h"}], "]"}]}], "\[CapitalNu]", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"2", 
         RowBox[{"J0", "^", "2"}], " ", 
         RowBox[{"(", 
          RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "+", 
        RowBox[{"2", 
         RowBox[{"J0", "^", "4"}], " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "^", "2"}]}]}], 
       ")"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"logSAR2", "[", "\[CapitalNu]", "]"}], "]"}], ",", 
        RowBox[{"Exp", "[", 
         RowBox[{"logSAR", "[", "\[CapitalNu]", "]"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[CapitalNu]", ",", "1", ",", "100"}], "}"}], ",", 
      RowBox[{"GridLines", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Root", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                RowBox[{"Exp", "[", 
                 RowBox[{"2", "h"}], "]"}]}], " ", 
               RowBox[{"Log", "[", "2", "]"}]}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "-", 
                 RowBox[{"2", " ", 
                  RowBox[{"J0", "^", "2"}]}], "+", 
                 RowBox[{"2", " ", 
                  RowBox[{"J0", "^", "4"}]}]}], ")"}], " ", "#1"}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  RowBox[{"J0", "^", "2"}]}], "-", 
                 RowBox[{"4", " ", 
                  RowBox[{"J0", "^", "4"}]}]}], ")"}], " ", 
               RowBox[{"#1", "^", "2"}]}], "+", 
              RowBox[{"2", " ", 
               RowBox[{"J0", "^", "4"}], " ", 
               RowBox[{"#1", "^", "3"}]}]}], "&"}], ",", "1"}], "]"}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", "Black"}], "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{
        RowBox[{
        "StringTemplate", "[", "\"\<\\!\\(J\\_0=`1`,h=`2`\\)\>\"", "]"}], "[", 
        RowBox[{"J0", ",", "h"}], "]"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
        "\"\<System size \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
         "\"\<\\!\\(SAR\\)\>\""}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "200"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[780]:=",ExpressionUUID->"8f3b4dd3-d5de-4f6e-8939-351543fbdeca"],

