Cell[TextData[{
 "At given ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["J", "0"], ",", "h"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3298131e-bfa0-4502-8882-346ea37e554c"],
 " point, the SAR decays with ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7bb905a2-ec1a-4086-aa5b-7f411c7012de"],
 " as"
}], "TextNoIndent",ExpressionUUID->"2366a2a8-e12e-4041-8dd5-8e8221f6b7a6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"J0", "=", "1"}], ",", 
     RowBox[{"h", "=", "3"}], ",", "dat", ",", "mdl"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dat", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], "}"}], ",", 
       RowBox[{"Normal", "[", 
        RowBox[{
         RowBox[{"ds", "[", 
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#J0", "==", "J0"}], "&&", 
              RowBox[{"#h", "==", "h"}]}], "&"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"\"\<n\>\"", ",", "\"\<mid\>\""}], "}"}]}], "]"}], "[", 
         RowBox[{"[", "Values", "]"}], "]"}], "]"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"mdl", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"dat", ",", 
       RowBox[{"LogisticSigmoid", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Exp", "[", "a", "]"}]}], " ", "x"}], "+", 
         RowBox[{"Exp", "[", "b", "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"b", ",", "1"}], "}"}]}], "}"}], ",", "x"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"mdl", "[", "x", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "15"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Gray", ",", "Dashed"}], "]"}]}]}], "]"}], ",", 
      RowBox[{"Graphics", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Translate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Point", "[", 
               RowBox[{"{", 
                RowBox[{"0", ",", "0"}], "}"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"AbsoluteThickness", "[", "1.2", "]"}], ",", 
                RowBox[{"Line", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"0", ",", "#"}], "}"}], "&"}], "/@", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"#4", "-", "#3"}], ",", 
                    RowBox[{"#2", "-", "#3"}]}], "}"}]}], "]"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Translate", "[", 
                   RowBox[{
                    RowBox[{"Line", "[", 
                    RowBox[{"Offset", "/@", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "2"}], ",", "0"}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "0"}], "}"}]}], "}"}]}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"#4", "-", "#3"}], ",", 
                   RowBox[{"#2", "-", "#3"}]}], "}"}]}]}], "}"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"#1", ",", "#3"}], "}"}]}], "]"}], "&"}], "@@@", 
         RowBox[{"Normal", "[", 
          RowBox[{
           RowBox[{"ds", "[", 
            RowBox[{
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"#J0", "==", "J0"}], "&&", 
                RowBox[{"#h", "==", "h"}]}], "&"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
              "\"\<n\>\"", ",", "\"\<low\>\"", ",", "\"\<mid\>\"", ",", 
               "\"\<high\>\""}], "}"}]}], "]"}], "[", 
           RowBox[{"[", "Values", "]"}], "]"}], "]"}]}], ",", 
        RowBox[{"Frame", "->", "True"}], ",", 
        RowBox[{"AspectRatio", "->", "0.6"}]}], "]"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\\!\\(\[VeryThinSpace]N\\)\>\"", ",", "\"\<\\!\\(p\\_0\\)\>\""}],
         "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", 
       RowBox[{
        RowBox[{
        "StringTemplate", "[", "\"\<\\!\\(J\\_0=`1`,h=`2`\\)\>\"", "]"}], "[", 
        RowBox[{"J0", ",", "h"}], "]"}]}], ",", 
      RowBox[{"ImageSize", "->", "200"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[113]:=",ExpressionUUID->"0bb94aa7-b8b3-43ea-8a39-7f42f089f676"],

