}], "TextNoIndent",ExpressionUUID->"baf07188-0cd0-48f4-9537-213b2d4b28fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "\[CapitalNu]crs", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalNu]crs", "[", 
      RowBox[{
       RowBox[{"J0_", "?", "NumericQ"}], ",", 
       RowBox[{"h_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"\[CapitalNu]", "/.", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "\[CapitalNu]"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"2", 
             RowBox[{"J0", "^", "2"}], " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{"2", "J0"}]}], ")"}]}]}], "-", 
            RowBox[{"2", "h"}]}], "]"}]}], "==", 
         RowBox[{"Log", "[", 
          RowBox[{"1", "/", "2"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"\[CapitalNu]", ",", 
          RowBox[{"h", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"2", "J0"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", 
              RowBox[{"J0", "^", "2"}]}], ")"}]}]}]}], "}"}]}], "]"}]}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"ListContourPlot", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"J0", ",", "h", ",", 
            RowBox[{"Log", "[", 
             RowBox[{"\[CapitalNu]crs", "[", 
              RowBox[{"J0", ",", "h"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"J0", ",", "0.02", ",", "1", ",", "0.04"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"h", ",", "0.1", ",", "8", ",", "0.2"}], "}"}]}], "]"}], 
        ",", "1"}], "]"}], ",", 
      RowBox[{"Contours", "->", 
       RowBox[{"Range", "[", 
        RowBox[{"0", ",", "6", ",", "0.5"}], "]"}]}], ",", 
      RowBox[{"ContourStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "1", "]"}], ",", 
         RowBox[{"Opacity", "[", "0.4", "]"}]}], "]"}]}], ",", 
      RowBox[{"ColorFunction", "->", "\"\<BeachColors\>\""}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", "6"}], "}"}]}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\\!\\(J\\_0\\)\>\"", ",", "\"\<\\!\\(\[VeryThinSpace]h\\)\>\""}],
         "}"}]}], ",", 
      RowBox[{"PlotLabel", "->", "\"\<\\!\\(log N\\_crs\\)\>\""}], ",", 
      RowBox[{"ImageSize", "->", "180"}]}], "]"}]}]}], "]"}]], "Input",
 CellLabel->
  "In[102]:=",ExpressionUUID->"9ea35e0a-c887-4441-92b1-db0538f9a7db"],

