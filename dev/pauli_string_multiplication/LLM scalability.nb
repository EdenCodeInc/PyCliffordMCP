Cell[TextData[{
 "Small-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "87a5cfe0-0c5a-433e-9fba-bf0a69d0c0d4"],
 " Expansion"
}], "Subsubsection",ExpressionUUID->"2180a7d5-3fce-480c-b549-12fa1a5ea1f8"],

Cell[TextData[{
 "If we assume the noise strength ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65c58f91-4012-4850-b927-f80adf1728ad"],
 " is weak, we can proceed with small-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4b1a91df-d48f-463d-a30d-6ca9e58c3323"],
 " expansion:"
}], "TextIndent",ExpressionUUID->"dad24a93-c36f-43b6-bdc3-eb5943e2c8bf"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    SubsuperscriptBox["Z", "J", "n"]}], "=", 
   RowBox[{
    SuperscriptBox["\[CapitalOmega]", "n"], 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"[", "s", "]"}]], 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"h", 
         RowBox[{
          UnderscriptBox["\[Sum]", 
           RowBox[{"i", ",", "a"}]], 
          SubsuperscriptBox["s", "i", "a"]}]}]], "(", 
       RowBox[{"1", "+", 
        RowBox[{
         SubsuperscriptBox["J", "0", "2"], 
         RowBox[{
          UnderscriptBox["\[Sum]", 
           RowBox[{
            RowBox[{"i", "<", "j"}], ",", 
            RowBox[{"a", "<", "b"}]}]], 
          RowBox[{
           SubsuperscriptBox["s", "i", "a"], 
           SubsuperscriptBox["s", "j", "a"], 
           SubsuperscriptBox["s", "i", "b"], 
           SubsuperscriptBox["s", "j", "b"]}]}]}], "+", 
        RowBox[{
         FractionBox[
          SubsuperscriptBox["J", "0", "4"], "2"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            UnderscriptBox["\[Sum]", 
             RowBox[{
              RowBox[{"i", "<", "j"}], ",", 
              RowBox[{"a", "<", "b"}]}]], 
            RowBox[{
             SubsuperscriptBox["s", "i", "a"], 
             SubsuperscriptBox["s", "j", "a"], 
             SubsuperscriptBox["s", "i", "b"], 
             SubsuperscriptBox["s", "j", "b"]}]}], ")"}], "2"]}], "+", 
        "\[Ellipsis]"}], ")"}], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"3ad47dc2-7bd8-\
4b30-8c51-b84555eee682"],

Cell["Now the Boltzmann weight can be factor to each spin,", "TextNoIndent",ExpressionUUID->"fba9a8f7-db30-4eca-89be-97eee9b93eb2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"h", 
      RowBox[{
       UnderscriptBox["\[Sum]", 
        RowBox[{"i", ",", "a"}]], 
       SubsuperscriptBox["s", "i", "a"]}]}]], "=", 
    RowBox[{
     UnderscriptBox["\[Product]", 
      RowBox[{"i", ",", "a"}]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"h", " ", 
       SubsuperscriptBox["s", "i", "a"]}]]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"af9eae03-d564-\
4d64-b9ea-c8af59bf8a56"],

Cell["\<\
the spin configuration summation can be carried out independently, and the \
calculation is tractable. For each spin,\
\>", "TextNoIndent",ExpressionUUID->"17c2d935-c4ae-48ef-b6e8-71e3b5310477"],

Cell["the partition function:", "Item",ExpressionUUID->"9278e70e-7ad5-4204-8fc6-9ec4d873336b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"z", ":=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[Sum]", "s"], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"h", " ", "s"}]]}], "=", 
     RowBox[{"2", " ", "cosh", " ", "h"}]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"85c96886-0329-\
42e5-9021-978bd416a65b"],

Cell["the magnetization:", "Item",ExpressionUUID->"0ff0f9b8-aae4-4bb3-83a7-5061576a72af"],

Cell[BoxData[
 FormBox[
  RowBox[{"m", ":=", 
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", "s", "\[RightAngleBracket]"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "z"], 
      RowBox[{
       UnderscriptBox["\[Sum]", "s"], 
       RowBox[{"s", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"h", " ", "s"}]]}]}]}], "=", 
     RowBox[{"tanh", " ", 
      RowBox[{"h", "."}]}]}]}]}], TraditionalForm]], "DisplayFormulaNumbered",\
ExpressionUUID->"27270c49-308d-4e34-9a67-e26c7bccc6e2"],

Cell["Therefore,", "TextNoIndent",ExpressionUUID->"fd36c4cd-650e-4ea0-af14-f05bb51a23cd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    UnderscriptBox["\[DoubleStruckCapitalE]", "J"], " ", 
    SubsuperscriptBox["Z", "J", "n"]}], "=", 
   RowBox[{
    SuperscriptBox["\[CapitalOmega]", "n"], 
    RowBox[{
     RowBox[{
      SuperscriptBox["z", 
       RowBox[{"n", " ", "N"}]], "(", 
      RowBox[{"1", "+", 
       RowBox[{
        FractionBox[
         SubsuperscriptBox["J", "0", "2"], "4"], "N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], " ", 
        SuperscriptBox["m", "4"]}], "+", 
       RowBox[{
        FractionBox[
         SubsuperscriptBox["J", "0", "4"], "2"], "N", " ", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}], " ", "n", " ", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          FractionBox["1", "4"], "+", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{"(", 
            RowBox[{"N", "+", "n", "-", "4"}], ")"}], 
           SuperscriptBox["m", "4"]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"N", "-", "2"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"n", "-", "2"}], ")"}], " ", 
           SuperscriptBox["m", "6"]}], "+", 
          RowBox[{
           FractionBox["1", "4"], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
