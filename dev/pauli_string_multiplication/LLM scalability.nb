Cell[BoxData[
 RowBox[{"ListContourPlot", "[", 
  RowBox[{
   RowBox[{"Normal", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ps", "[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{
         "\"\<J0\>\"", ",", "\"\<h\>\"", ",", "\"\<log\[Delta]n\>\""}], 
         "}"}]}], "]"}], "[", 
      RowBox[{"All", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\"\<J0\>\"", "->", "Log"}], ",", 
         RowBox[{"\"\<h\>\"", "->", "Log"}]}], "}"}]}], "]"}], "[", 
     RowBox[{"[", "Values", "]"}], "]"}], "]"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\\!\\(log J\\_0\\)\>\"", ",", 
      "\"\<\\!\\(\[VeryThinSpace]log h\\)\>\""}], "}"}]}], ",", 
   RowBox[{
   "PlotLabel", "->", "\"\<\\!\\(log \[Delta]\[ImplicitPlus]N\\)\>\""}], ",", 
   
   RowBox[{"ImageSize", "->", "180"}]}], "]"}]], "Input",
