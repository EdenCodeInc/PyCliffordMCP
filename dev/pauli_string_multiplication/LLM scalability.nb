Cell["This is similar to what we observed in the numerics.", "TextNoIndent",ExpressionUUID->"ca9b97f4-d4f2-4050-bba8-94dc90a0d8aa"],

Cell["import torch", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.968172701161421*^9, 3.968172710841876*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"7d49a9cc-56b4-4007-98dd-a40eb935bb75"],

Cell[TextData[{
 "We propose an ",
 StyleBox["empirical formula",
  FontWeight->"Bold"],
 " for SAR"
}], "TextIndent",
 CellChangeTimes->{
  3.96834245426158*^9},ExpressionUUID->"a6f352d0-3668-4dc8-a8f1-a4b6d6f8a972"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"SAR", "(", "N", ")"}], "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "N"}], " ", 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"2", 
           SubsuperscriptBox["J", "0", "2"]}], 
          RowBox[{"1", "+", 
           RowBox[{"2", 
            SubscriptBox["J", "0"]}]}]], 
         RowBox[{"(", 
          RowBox[{"N", "-", "1"}], ")"}]}], "-", 
        RowBox[{"2", "h"}]}], ")"}]}], ")"}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "xref:142327",ExpressionUUID->"f8dc7324-43c6-46f4-b7b0-cdc6070247d2"],

Cell[TextData[{
 "Define the crossover scale ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["N", "crs"], TraditionalForm]],ExpressionUUID->
  "d2495d2a-487d-4336-a4be-92fc3b60befc"],
 " by the solution of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"SAR", "(", 
     SubscriptBox["N", "crs"], ")"}], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "5233bbff-a9a7-4dde-bf2f-e6843caa3de0"],
 ", then fit the data with formula below"
}], "TextIndent",
 CellChangeTimes->{
  3.96834245426158*^9, {3.968342507420088*^9, 3.968342554687894*^9}, {
   3.968346424933079*^9, 
   3.9683464253595953`*^9}},ExpressionUUID->"434c81aa-2ca2-4b94-850d-\
b127750804c4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"SAR", "(", "N", ")"}], "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "N"}], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"(", 
          RowBox[{"N", "-", "1"}], ")"}]}], "-", "\[Beta]"}]]}], ")"}]}], ",",
    " ", 
   RowBox[{"\[Alpha]", "=", 
    FractionBox[
     RowBox[{"2", 
      SubsuperscriptBox["J", "0", "2"]}], 
     RowBox[{"1", "+", 
      RowBox[{"2", 
       SubscriptBox["J", "0"]}]}]]}], ",", " ", 
   RowBox[{"\[Beta]", "=", 
    RowBox[{"2", "h"}]}]}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.968175696508306*^9, 3.9681757216045094`*^9}, {
  3.968342336225116*^9, 3.9683423770186987`*^9}, {3.968350596788632*^9, 
  3.968350602143656*^9}},ExpressionUUID->"9b0de839-4435-48fa-aee2-\
a0f60061b38b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"file", ",", "series", ",", "models"}], "}"}], ",", 
   RowBox[{
    RowBox[{"file", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", 
        "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
        "\"\<letter_replace_13_plot.pt\>\""}], "}"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"series", "=", 
     RowBox[{"GetPy", "[", 
      RowBox[{
      "\"\<import torch, numpy as np\\n\>\"", "<>", 
       "\"\<d = torch.load(r'''\>\"", "<>", 
       RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", "<>", 
       "\"\<{k: np.stack([v['L'], v['accuracy']], axis=1).tolist() for k, v \
in d['series'].items()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"models", "=", 
     RowBox[{"Association", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"key", "->", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{
           RowBox[{"series", "[", "key", "]"}], ",", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "\[CapitalNu]"}], " ", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"\[Alpha]", " ", 
                RowBox[{"(", 
                 RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
               "\[Beta]"}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"\[Alpha]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "0.02"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "0.1"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "0.1"}], ",", 
                  RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "0.1"}], ",", 
                  RowBox[{"\"\<claude-sonnet-4-20250514\>\"", "->", "0.1"}]}],
                  "|>"}], "[", "key", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"\[Beta]", ",", 
               RowBox[{
                RowBox[{"<|", 
                 RowBox[{
                  RowBox[{"\"\<gpt-5\>\"", "->", "8"}], ",", 
                  RowBox[{"\"\<gemini-2.5-flash\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<gemini-2.5-pro\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<grok-4-fast-reasoning\>\"", "->", "6"}], ",", 
                  RowBox[{"\"\<claude-sonnet-4-20250514\>\"", "->", "6"}]}], 
                 "|>"}], "[", "key", "]"}]}], "}"}]}], "}"}], ",", 
           "\[CapitalNu]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"key", ",", 
          RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Row", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"models", "[", "key", "]"}], "[", "\[CapitalNu]", "]"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalNu]", ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
              RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], ",", 
             RowBox[{
              RowBox[{"series", "[", "key", "]"}], "\[LeftDoubleBracket]", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "1"}], "\[RightDoubleBracket]"}]}], 
            "}"}], ",", 
           RowBox[{"PlotStyle", "->", "Gray"}]}], "]"}], ",", 
         RowBox[{"ListPlot", "[", 
          RowBox[{"series", "[", "key", "]"}], "]"}], ",", 
         RowBox[{"PlotLabel", "->", "key"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"Epilog", "->", 
          RowBox[{"Text", "[", 
           RowBox[{
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
               "StringTemplate", "[", 
                "\"\<\\!\\(\[Alpha]=`1`\\)\\n\\!\\(\[Beta]=`2`\\)\>\"", "]"}],
                "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"NumberForm", "[", 
                    RowBox[{"#", ",", "3"}], "]"}], "&"}], "/@", 
                  RowBox[{"{", 
                   RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}]}], "/.", 
                 RowBox[{
                  RowBox[{"models", "[", "key", "]"}], "[", 
                  "\"\<BestFitParameters\>\"", "]"}]}], ")"}]}], ",", "12", 
              ",", 
              RowBox[{"LineSpacing", "->", 
               RowBox[{"{", 
                RowBox[{"0", ",", "12"}], "}"}]}]}], "]"}], ",", 
            RowBox[{"Scaled", "@", 
             RowBox[{"{", 
              RowBox[{"0.9", ",", "0.9"}], "}"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], ",", 
         RowBox[{"ImageSize", "->", "200"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           RowBox[{
           "\"\<String length \\!\\(\[VeryThinSpace]N\\)\>\"", ",", 
            "\"\<SAR\>\""}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"key", ",", 
         RowBox[{"Keys", "@", "series"}]}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.968172902194248*^9, 3.9681729021983843`*^9}, 
   3.968172982434456*^9, {3.9681730333007317`*^9, 3.968173058475925*^9}, {
   3.968174018798685*^9, 3.968174034663683*^9}, {3.96817407753721*^9, 
   3.968174180880373*^9}, {3.9681742844272556`*^9, 3.968174332675606*^9}, {
   3.968174496022384*^9, 3.968174695283437*^9}, {3.96817473401198*^9, 
   3.968174751714883*^9}, {3.968174794214581*^9, 3.96817515586873*^9}, {
   3.968175238881653*^9, 3.968175586757772*^9}, {3.96828063404703*^9, 
   3.968280721803963*^9}, {3.968350585435306*^9, 3.968350588553982*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"5b732830-3b40-4f32-99dc-6ef431c30c14"],

