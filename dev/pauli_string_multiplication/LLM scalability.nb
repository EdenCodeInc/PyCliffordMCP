 FormBox[
  RowBox[{
   RowBox[{"(", "D", ")"}], "=", 
   RowBox[{"2", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"i", "<", "j"}], ")"}], "\[NotEqual]", 
        RowBox[{"(", 
         RowBox[{"k", "<", "l"}], ")"}]}], "\[LineSeparator]", 
