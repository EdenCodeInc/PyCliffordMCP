Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "\[CapitalNu]crs", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalNu]crs", "[", 
      RowBox[{
       RowBox[{"\[Alpha]_", "?", "NumericQ"}], ",", 
       RowBox[{"\[Beta]_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}], "/.", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}]}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"\[Alpha]", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Exp", "[", "log\[CapitalNu]", "]"}], "-", "1"}], 
              ")"}]}], "-", "\[Beta]"}], "]"}]}], "==", 
         RowBox[{"Log", "[", 
          RowBox[{"1", "/", "2"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"log\[CapitalNu]", ",", 
          RowBox[{"Log", "[", 
           RowBox[{"\[Beta]", "/", "\[Alpha]"}], "]"}]}], "}"}]}], "]"}]}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"ListContourPlot", "[", 
