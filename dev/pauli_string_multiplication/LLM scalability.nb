Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[CapitalNu]", "=", "4"}], ",", 
     RowBox[{"n", "=", "5"}], ",", "series1", ",", "series2"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"series1", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Expand", "[", 
        RowBox[{"Normal", "[", 
         RowBox[{"Series", "[", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"J0", "^", "2"}], " ", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"s", "[", 
                 RowBox[{"i", ",", "a"}], "]"}], 
                RowBox[{"s", "[", 
                 RowBox[{"j", ",", "a"}], "]"}], 
                RowBox[{"s", "[", 
                 RowBox[{"i", ",", "b"}], "]"}], 
                RowBox[{"s", "[", 
                 RowBox[{"j", ",", "b"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "2", ",", "\[CapitalNu]"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", 
                 RowBox[{"i", "-", "1"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"a", ",", "2", ",", "n"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"b", ",", "1", ",", 
                 RowBox[{"a", "-", "1"}]}], "}"}]}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"J0", ",", "0", ",", "4"}], "}"}]}], "]"}], "]"}], "]"}], 
       "/.", 
       RowBox[{
        RowBox[{
         RowBox[{"s", "[", "__", "]"}], "^", "2"}], ":>", "1"}]}], "/.", 
      RowBox[{"_s", "->", "m"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"series2", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"J0", "^", "2"}], 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[CapitalNu]", 
           RowBox[{"(", 
            RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "n", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}], "/", "4"}]}], "}"}], ".", 
         RowBox[{"{", 
          RowBox[{"m", "^", "4"}], "}"}]}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"J0", "^", "4"}], "/", "2"}], " ", "\[CapitalNu]", 
        RowBox[{"(", 
         RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "n", 
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"1", "/", "4"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[CapitalNu]", "+", "n", "-", "4"}], ")"}], "/", "2"}], 
           ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[CapitalNu]", "-", "2"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"n", "-", "2"}], ")"}]}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[CapitalNu]", 
               RowBox[{"(", 
                RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], "n", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"n", "-", "1"}], ")"}], "/", "4"}]}], "-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "\[CapitalNu]"}], "-", "3"}], ")"}], 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "n"}], "-", "3"}], ")"}]}]}], ")"}], "/", 
            "4"}]}], "}"}], ".", 
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"m", "^", "4"}], ",", 
