               RowBox[{"{", 
                RowBox[{
                 RowBox[{"NotebookDirectory", "[", "]"}], ",", 
                 "\"\<direct_multiplication\>\"", ",", "\"\<records\>\"", 
                 ",", "\"\<pauli_multiply_all_plot.pt\>\""}], "}"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"series", "=", 
              RowBox[{"GetPy", "[", 
               RowBox[{
               "\"\<import torch\\n\>\"", "<>", "\"\<d = torch.load(r'''\>\"",
                 "<>", 
                RowBox[{"ToString", "[", "file", "]"}], "<>", 
                "\"\<''')\\n\>\"", "<>", "\"\<import numpy as np\\n\>\"", 
                "<>", "\"\<{w: {m: np.stack([v['N'], v['accuracy']], \
axis=1).tolist() for (m, v) in d['series'].get(w, {}).items()} for w in \
d['series'].keys()}\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"models", "=", 
              RowBox[{"Association", "@", 
