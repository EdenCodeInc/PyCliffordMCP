Cell["import torch", "ExternalLanguage",
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.96972187217288*^9, 3.9697218759456472`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"65b6db0a-f713-4614-a340-9159ba752a5f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Print", "[", 
  RowBox[{
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"file", ",", "series", ",", "models", ",", "title"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"file", "=", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
          "\"\<letter_replace_all_plot.pt\>\""}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"series", "=", 
       RowBox[{"GetPy", "[", 
        RowBox[{
        "\"\<import torch\\n\>\"", "<>", "\"\<d = torch.load(r'''\>\"", "<>", 
         
         RowBox[{"ToString", "[", "file", "]"}], "<>", "\"\<''')\\n\>\"", 
         "<>", "\"\<import numpy as np\\n\>\"", "<>", 
         "\"\<{t: {m: np.stack([v['L'], v['accuracy']], axis=1).tolist() for \
(m, v) in d['series'].get(t, {}).items()} for t in d['series'].keys()}\>\""}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"models", "=", 
       RowBox[{"Association", "@", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"task", ",", "model"}], "}"}], "->", 
            RowBox[{"NonlinearModelFit", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"series", "[", "task", "]"}], "[", "model", "]"}], ",", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "\[CapitalNu]"}], " ", 
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"\[Alpha]", " ", 
                   RowBox[{"(", 
                    RowBox[{"\[CapitalNu]", "-", "1"}], ")"}]}], "-", 
                  "\[Beta]"}], "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"\[Alpha]", ",", "0.1"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"\[Beta]", ",", "6"}], "}"}]}], "}"}], ",", 
              "\[CapitalNu]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"task", ",", 
             RowBox[{"Keys", "[", "series", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"model", ",", 
             RowBox[{"Keys", "[", 
              RowBox[{"series", "[", "task", "]"}], "]"}]}], "}"}]}], "]"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "\[Alpha]", ",", "\[Beta]", ",", "\"\<gemini-2.5-flash\>\""}], 
          "}"}], "/.", " ", 
         RowBox[{
          RowBox[{"models", "[", 
           RowBox[{"{", 
            RowBox[{"#1", ",", "\"\<gemini-2.5-flash\>\""}], "}"}], "]"}], 
          "[", "\"\<BestFitParameters\>\"", "]"}]}], "&"}], "@@@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\"\<letter_replace_4\>\"", ",", "\"\<alphabet-4\>\""}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<letter_replace_9\>\"", ",", "\"\<alphabet-9\>\""}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<letter_replace_13\>\"", ",", "\"\<alphabet-13\>\""}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\"\<letter_replace_26\>\"", ",", "\"\<alphabet-26\>\""}], 
          "}"}]}], "}"}]}]}]}], "\[IndentingNewLine]", "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"file", ",", "series", ",", "models", ",", "title"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"file", "=", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          "\"\<letter_replace_13\>\"", ",", "\"\<records\>\"", ",", 
          "\"\<letter_replace_all_plot.pt\>\""}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"series", "=", 
       RowBox[{"GetPy", "[", 
        RowBox[{
        "\"\<import torch\\n\>\"", "<>", "\"\<d = torch.load(r'''\>\"", "<>", 
         
