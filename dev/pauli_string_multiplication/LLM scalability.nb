Cell[TextData[{
 "Small-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["J", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47743b73-6650-43af-89db-b22ebf145fe2"],
 " and large-",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "31317afd-3452-4caf-a76d-2d0f15fa51fe"],
 " limit."
}], "Item",ExpressionUUID->"c2d2b887-4acf-484c-af97-5feeb5f2c528"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"log", " ", "SAR"}], "=", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], "h"}]]}], " ", "N", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"2", 
        RowBox[{
         SubsuperscriptBox["J", "0", "2"], "(", 
         RowBox[{"N", "-", "1"}], ")"}]}], "+", 
       RowBox[{"2", 
        SuperscriptBox[
         RowBox[{
          SubsuperscriptBox["J", "0", "4"], "(", 
          RowBox[{"N", "-", "1"}], ")"}], "2"]}]}], ")"}], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "xref:138755",ExpressionUUID->"68faf92c-d7a9-4e00-b69f-a09df8b1c91a"],

Cell[CellGroupData[{

Cell[TextData[{
 "Derive Eq.\[NonBreakingSpace](",
 
 CounterBox["DisplayFormulaNumbered", "xref:138755"],
 ") by large-",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7a3fa992-2198-4cb3-a824-ca9844a2fa04"],
 " expansion."
}], "Exercise",ExpressionUUID->"24776268-2160-4237-ac6c-35a3139bc7a0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Normal", "@", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"h", "=", 
          RowBox[{"Log", "[", "eh", "]"}]}], ",", "logSAR"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"logSAR", "=", 
        RowBox[{
         RowBox[{"\[CapitalNu]", 
          RowBox[{"(", 
           RowBox[{"h", "-", 
            RowBox[{"Log", "[", 
             RowBox[{"2", " ", 
              RowBox[{"Cosh", "[", "h", "]"}]}], "]"}]}], ")"}]}], "+", 
         RowBox[{
          RowBox[{
           RowBox[{"J0", "^", "2"}], "/", "4"}], "\[CapitalNu]", 
          RowBox[{"(", 
           RowBox[{"\[CapitalNu]", "-", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{
             RowBox[{"Tanh", "[", "h", "]"}], "^", "4"}], "+", 
            RowBox[{
             RowBox[{"J0", "^", "2"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"1", "/", "2"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[CapitalNu]", "-", "4"}], ")"}], 
                RowBox[{
                 RowBox[{"Tanh", "[", "h", "]"}], "^", "4"}]}], "-", 
               RowBox[{"4", 
                RowBox[{"(", 
                 RowBox[{"\[CapitalNu]", "-", "2"}], ")"}], " ", 
                RowBox[{
                 RowBox[{"Tanh", "[", "h", "]"}], "^", "6"}]}], "+", 
               RowBox[{
                RowBox[{"3", "/", "2"}], 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "\[CapitalNu]"}], "-", "3"}], ")"}], 
                RowBox[{
                 RowBox[{"Tanh", "[", "h", "]"}], "^", "8"}]}]}], ")"}]}]}], 
           ")"}]}]}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"eh", ",", "\[Infinity]", ",", "4"}], "}"}]}], "]"}]}], "/.", 
  RowBox[{"eh", "->", 
   RowBox[{"Exp", "[", "h", "]"}]}]}]], "Input",
 CellLabel->
  "In[621]:=",ExpressionUUID->"b6a7ac44-6fba-4287-8ca1-259853894c18"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "2"}], " ", "h"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "\[CapitalNu]"}], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      SuperscriptBox["J0", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "8"}], "-", 
        RowBox[{"8", " ", 
         SuperscriptBox["J0", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[CapitalNu]"}], ")"}]}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[CapitalNu]"}], ")"}], " ", 
      "\[CapitalNu]"}]}], ")"}]}], "+", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "4"}], " ", "h"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox["\[CapitalNu]", "2"], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      SuperscriptBox["J0", "2"], " ", 
      RowBox[{"(", 
       RowBox[{"32", "+", 
        RowBox[{"128", " ", 
         SuperscriptBox["J0", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[CapitalNu]"}], ")"}]}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[CapitalNu]"}], ")"}], " ", 
      "\[CapitalNu]"}]}], ")"}]}]}]], "Output",
 CellLabel->
  "Out[621]=",ExpressionUUID->"b0a3f6cf-497b-4e53-b69c-a129a4f69227"]
}, {2}]]
}, Closed]],

