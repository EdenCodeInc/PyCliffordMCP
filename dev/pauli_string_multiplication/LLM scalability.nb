         "freeformCursorMode" -> True, 
          "placement" -> {"x" -> "All", "y" -> "None"}}}}, "GridLinesInFront" -> 
    True},
  PlotLabel->FormBox["\"\\!\\(log N\\_crs\\)\"", TraditionalForm],
  PlotRange->{{0, 0.98}, {0, 7.9}},
