{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/Users/home/Documents/GitHub",
                "/Users/home/Library/CloudStorage/Dropbox"
            ]
        },
        "pyclifford": {
            "name": "pyclifford",
            "version": "0.1.0",
            "description": "MCP server to use PyClifford package",
            "command": "uv",
            "args": [
                "run",
                "--with",
                "mcp[cli]",
                "mcp",
                "run",
                "/Users/home/Documents/GitHub/PyClifford_MCP/mcp_server/server.py"
            ]
        }
    }
} 